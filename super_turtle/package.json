{
  "name": "superturtle",
  "version": "0.2.5",
  "description": "Code from anywhere with your voice. Autonomous coding system controlled from Telegram.",
  "scripts": {
    "test:pack": "bash tests/npm-package-smoke.sh",
    "test:init-safe": "bash tests/init-non-destructive.sh",
    "test:init-git-binding": "bash tests/init-git-binding.sh",
    "test:e2b-webhook-poc": "node tests/e2b-webhook-poc.test.js"
  },
  "dependencies": {
    "@e2b/code-interpreter": "^2.0.0",
    "@grammyjs/runner": "^2.0.3",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@openai/codex-sdk": "0.105.0",
    "grammy": "^1.38.4",
    "openai": "^6.15.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.2.1"
  },
  "author": {
    "name": "Richard Mladek",
    "url": "https://github.com/Rigos0"
  },
  "bin": {
    "superturtle": "bin/superturtle.js"
  },
  "files": [
    "__init__.py",
    "bin/",
    "claude-telegram-bot/src/**/*.ts",
    "!claude-telegram-bot/src/**/*.test.ts",
    "claude-telegram-bot/src/handlers/__fixtures__/",
    "claude-telegram-bot/bot_control_mcp/",
    "claude-telegram-bot/send_turtle_mcp/",
    "claude-telegram-bot/scripts/",
    "claude-telegram-bot/systemd/",
    "claude-telegram-bot/package.json",
    "claude-telegram-bot/tsconfig.json",
    "claude-telegram-bot/mcp-config.ts",
    "claude-telegram-bot/mcp-config.example.ts",
    "claude-telegram-bot/live.sh",
    "claude-telegram-bot/run-loop.sh",
    "claude-telegram-bot/.env.example",
    "meta/*.md",
    "meta/claude-meta",
    "state/__init__.py",
    "subturtle/*.py",
    "subturtle/pyproject.toml",
    "subturtle/ctl",
    "subturtle/browser-screenshot.sh",
    "subturtle/start-tunnel.sh",
    "subturtle/README.md",
    "subturtle/claude-md-guard/*.sh",
    "subturtle/claude-md-guard/config.sh",
    "subturtle/claude-md-guard/README.md",
    "subturtle/subturtle_loop/__init__.py",
    "subturtle/subturtle_loop/agents.py",
    "state/*.py",
    "templates/",
    "templates/.claude/",
    "setup",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "keywords": [
    "claude",
    "telegram",
    "ai",
    "coding",
    "agent",
    "autonomous",
    "voice",
    "mobile",
    "bun",
    "tmux",
    "claude-code",
    "mcp"
  ],
  "license": "MIT",
  "homepage": "https://www.superturtle.dev",
  "bugs": {
    "url": "https://github.com/Rigos0/superturtle/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Rigos0/superturtle.git"
  }
}
