# Claude Telegram Bot - Environment Configuration
# Copy this file to `.env` for local use. Never commit real credentials.

# ==============================================================================
# REQUIRED
# ==============================================================================

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=<telegram_bot_token_from_botfather>

# Comma-separated Telegram user IDs allowed to use the bot
# Find your ID: message @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=<telegram_user_id>

# ==============================================================================
# RECOMMENDED
# ==============================================================================

# Working directory where Claude runs (loads CLAUDE.md, skills, MCP config)
# Note: `superturtle start` sets this automatically to the current directory,
# but you may want to override it when running the bot manually.
CLAUDE_WORKING_DIR=/absolute/path/to/your/workdir

# OpenAI API key for voice message transcription
# Without this, voice messages won't work
OPENAI_API_KEY=<optional_openai_api_key>

# Startup default provider when no saved last-used provider exists yet.
# Valid values: claude, codex
# Saved runtime preference still wins across restarts.
# If set to codex, also enable Codex below and ensure the local codex CLI is available.
# MAIN_PROVIDER=claude

# Keep routine per-tool progress messages out of Telegram by default.
# Final answers and important failures still appear.
SHOW_TOOL_STATUS=false

# ==============================================================================
# OPTIONAL - Telegram Transport
# ==============================================================================

# Default local behavior uses long polling and exposes no public HTTP port.
# TELEGRAM_TRANSPORT=polling
#
# Webhook mode is intended for remote runtimes behind an ingress/tunnel.
# TELEGRAM_TRANSPORT=webhook
# TELEGRAM_WEBHOOK_URL=https://example.test/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=<optional_secret_token>
# PORT=3000

# ==============================================================================
# OPTIONAL - Dashboard (Local Web UI)
# ==============================================================================

# Local dashboard is enabled by default.
# Set to false to disable it completely.
# DASHBOARD_ENABLED=false
#
# Optional dashboard access lock for advanced setups only.
# Leave this unset for normal local-only use.
# Set it only if you expose the dashboard beyond localhost or share the machine with other users.
# If set, the startup log prints the full ready-to-open URL automatically.
# DASHBOARD_AUTH_TOKEN=<optional_random_token>

# ==============================================================================
# OPTIONAL - Security
# ==============================================================================

# Comma-separated paths Claude can access
# Default: working dir, ~/Documents, ~/Downloads, ~/Desktop, ~/.claude
# Note: Setting this OVERRIDES defaults. Include ~/.claude for plan mode to work.
# ALLOWED_PATHS=/Users/yourname/personal,/Users/yourname/projects,/Users/yourname/.claude

# Rate limiting (token bucket)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=20
# RATE_LIMIT_WINDOW=60

# ==============================================================================
# OPTIONAL - Claude Authentication
# ==============================================================================

# API key for environments without Claude Code CLI auth
# Get from: https://console.anthropic.com/
# Note: API usage is billed per token - CLI auth is more cost-effective
# ANTHROPIC_API_KEY=<optional_anthropic_api_key>

# Path to Claude CLI (auto-detected from PATH by default)
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# ==============================================================================
# OPTIONAL - Codex
# ==============================================================================

# Enable Codex integration for /usage stats (default: disabled)
# Set to true to include Codex usage in /usage.
# Requires local `codex` CLI access (authenticated on this machine).
# No OPENAI_ADMIN_KEY is required.
CODEX_ENABLED=false

# Meta-agent Codex runtime policy (secure defaults)
# Allowed sandbox values: read-only, workspace-write, danger-full-access
# META_CODEX_SANDBOX_MODE=workspace-write
#
# Allowed approval values: never, on-request, on-failure, untrusted
# META_CODEX_APPROVAL_POLICY=never
#
# Enable network access for Codex runtime (true/false)
# META_CODEX_NETWORK_ACCESS=false

# ==============================================================================
# OPTIONAL - Runtime Timeouts
# ==============================================================================

# Stall detection for streaming (milliseconds)
# CLAUDE_EVENT_STREAM_STALL_TIMEOUT_MS=90000
# CLAUDE_TOOL_ACTIVE_STALL_TIMEOUT_MS=240000
# CODEX_EVENT_STREAM_STALL_TIMEOUT_MS=90000

# ==============================================================================
# OPTIONAL - Default Models & Effort
# ==============================================================================

# Claude defaults used only when there are no saved Telegram preferences yet.
# Valid models: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
# DEFAULT_CLAUDE_MODEL=claude-sonnet-4-6
#
# Valid effort levels: low, medium, high
# DEFAULT_CLAUDE_EFFORT=medium
#
# Codex defaults used only when there are no saved Telegram preferences yet.
# Valid models: gpt-5.3-codex, gpt-5.3-codex-spark
# DEFAULT_CODEX_MODEL=gpt-5.3-codex-spark
#
# Valid effort levels: minimal, low, medium, high, xhigh
# DEFAULT_CODEX_EFFORT=low

# ==============================================================================
# OPTIONAL - Voice Transcription
# ==============================================================================

# Path to a text file with additional context for voice transcription
# (names, technical terms, etc. — keeps personal context outside this repo)
# TRANSCRIPTION_CONTEXT_FILE=/path/to/transcription-context.txt

# ==============================================================================
# OPTIONAL - Scheduled Messages
# ==============================================================================

# Disable scheduled "turtle greetings"
# TURTLE_GREETINGS=false

# ==============================================================================
# OPTIONAL - Logging
# ==============================================================================

# Log level: trace, debug, info, warn, error, fatal
# LOG_LEVEL=info

# Audit log path
# AUDIT_LOG_PATH=/tmp/claude-telegram-audit.log

# Output audit logs as JSON (default: human-readable)
# AUDIT_LOG_JSON=false
