# Reference env template for the live project env in this directory.
#
# Actual runtime config is stored in `.env` next to this file, together with
# `.superturtle/project.json` and other SuperTurtle state files.
# `superturtle init` creates `.env` and seeds this `.env.example` reference file.
#
# Copy the keys you need into `.env`. Do not commit real credentials.

# ==============================================================================
# REQUIRED
# ==============================================================================

TELEGRAM_BOT_TOKEN=<telegram_bot_token_from_botfather>
TELEGRAM_ALLOWED_USERS=<telegram_user_id>

# ==============================================================================
# COMMON OPTIONAL
# ==============================================================================

# CLAUDE_WORKING_DIR=/absolute/path/to/your/project
# OPENAI_API_KEY=<optional_openai_api_key>
# SHOW_TOOL_STATUS=false
# TURTLE_GREETINGS=true

# ==============================================================================
# DRIVER DEFAULTS
# ==============================================================================

# MAIN_PROVIDER=claude
# DEFAULT_CLAUDE_MODEL=claude-opus-4-6
# DEFAULT_CLAUDE_EFFORT=high
# CODEX_ENABLED=false
# DEFAULT_CODEX_MODEL=gpt-5.3-codex
# DEFAULT_CODEX_EFFORT=medium
# META_CODEX_SANDBOX_MODE=workspace-write
# META_CODEX_APPROVAL_POLICY=never
# META_CODEX_NETWORK_ACCESS=false
# CLAUDE_CLI_PATH=/absolute/path/to/claude

# ==============================================================================
# SECURITY
# ==============================================================================

# ALLOWED_PATHS=/Users/you/project,/Users/you/.claude
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=20
# RATE_LIMIT_WINDOW=60

# ==============================================================================
# DASHBOARD
# ==============================================================================

# DASHBOARD_ENABLED=true
# DASHBOARD_AUTH_TOKEN=<optional_random_token>

# ==============================================================================
# TELEGRAM TRANSPORT
# ==============================================================================

# TELEGRAM_TRANSPORT=polling
# TELEGRAM_WEBHOOK_URL=https://example.com/telegram/webhook
# TELEGRAM_WEBHOOK_HOST=0.0.0.0
# TELEGRAM_WEBHOOK_PORT=3000
# PORT=3000
# TELEGRAM_WEBHOOK_SECRET=<optional_secret_token>
# TELEGRAM_WEBHOOK_HEALTH_PATH=/healthz
# TELEGRAM_WEBHOOK_READY_PATH=/readyz
# TELEGRAM_WEBHOOK_REGISTER=true

# ==============================================================================
# TIMEOUTS AND LOGGING
# ==============================================================================

# CLAUDE_TOOL_DISCOVERY_TIMEOUT_MS=5000
# CLAUDE_EVENT_STREAM_STALL_TIMEOUT_MS=90000
# CLAUDE_TOOL_ACTIVE_STALL_TIMEOUT_MS=240000
# CODEX_EVENT_STREAM_STALL_TIMEOUT_MS=90000
# LOG_LEVEL=info
# AUDIT_LOG_PATH=/tmp/claude-telegram-audit.log
# AUDIT_LOG_JSON=false
# SUPERTURTLE_TMUX_SESSION=superturtle-custom
# SUPERTURTLE_LOOP_LOG_PATH=/tmp/claude-telegram-custom.log

# ==============================================================================
# VOICE TRANSCRIPTION
# ==============================================================================

# TRANSCRIPTION_CONTEXT_FILE=/absolute/path/to/transcription-context.txt




# ==============================================================================
# UNDER_CONSTRUCTION
# ==============================================================================
# E2B_API_KEY=<optional_e2b_api_key>

# ==============================================================================
# REMOTE / TELEPORT RUNTIME OVERRIDES
# ==============================================================================

# SUPERTURTLE_RUNTIME_ROLE=teleport-remote
# SUPERTURTLE_REMOTE_MODE=control
# SUPERTURTLE_RUNTIME_INSTALL_SPEC=superturtle@0.2.5
# SUPERTURTLE_TELEPORT_CODEX_AUTH_PATH=/absolute/path/to/codex-auth.json

# ==============================================================================
# E2B TEMPLATE BUILD OVERRIDES
# ==============================================================================

# SUPERTURTLE_E2B_TEMPLATE_NAME=superturtle-managed-runtime
# SUPERTURTLE_E2B_TEMPLATE_CHANNEL=latest
# SUPERTURTLE_E2B_TEMPLATE_VERSION=v0.2.5
# SUPERTURTLE_E2B_TEMPLATE_TAGS=latest
# SUPERTURTLE_E2B_TEMPLATE_CPU=2
# SUPERTURTLE_E2B_TEMPLATE_MEMORY_MB=2048
# SUPERTURTLE_E2B_BUN_VERSION=1.3.5
# SUPERTURTLE_CLAUDE_CODE_VERSION=2.1.76
# SUPERTURTLE_CODEX_INSTALL_SPEC=@openai/codex
