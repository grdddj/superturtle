#!/usr/bin/env bash
set -euo pipefail

# --- Configuration ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SUBTURTLE_LIB_DIR="${SCRIPT_DIR}/lib"

source_subturtle_module() {
  local module_path="${SUBTURTLE_LIB_DIR}/$1"
  if [[ ! -f "$module_path" ]]; then
    echo "ERROR: missing subturtle shell module: ${module_path}" >&2
    exit 1
  fi

  # shellcheck source=/dev/null
  source "$module_path"
}

source_subturtle_module "env.sh"
source_subturtle_module "shared.sh"
source_subturtle_module "conductor.sh"
source_subturtle_module "commands.sh"

# SUPER_TURTLE_DIR: where the superturtle package is installed (code)
SUPER_TURTLE_DIR="${SUPER_TURTLE_DIR:-$(cd "${SCRIPT_DIR}/.." && pwd)}"
# PROJECT_DIR: the user's working directory (data/state)
PROJECT_DIR="${SUPER_TURTLE_PROJECT_DIR:-${CLAUDE_WORKING_DIR:-$(cd "${SCRIPT_DIR}/../.." && pwd)}}"
SUBTURTLES_DIR="${PROJECT_DIR}/.superturtle/subturtles"
DEFAULT_TIMEOUT="1h"
CRON_JOBS_FILE="${PROJECT_DIR}/.superturtle/cron-jobs.json"
RUN_STATE_DIR="${PROJECT_DIR}/.superturtle/state"
RUNS_JSONL_FILE="${RUN_STATE_DIR}/runs.jsonl"
HANDOFF_MD_FILE="${RUN_STATE_DIR}/handoff.md"
RUN_STATE_WRITER="${SUPER_TURTLE_DIR}/state/run_state_writer.py"
CLAUDE_MD_GUARD_VALIDATE="${SCRIPT_DIR}/claude-md-guard/validate.sh"

# Use subturtle venv if available, otherwise system python3
PYTHON="${SCRIPT_DIR}/.venv/bin/python3"
if [[ ! -x "$PYTHON" ]]; then
  PYTHON="python3"
fi

# Support both monorepo imports (`super_turtle.*`) and packaged imports
# (`subturtle`, `state`) by exposing both the package root and its parent.
export PYTHONPATH="${SUPER_TURTLE_DIR}:${SUPER_TURTLE_DIR%/*}${PYTHONPATH:+:$PYTHONPATH}"

migrate_legacy_runtime_layout "$PROJECT_DIR"

usage() {
  echo "Usage: ./super_turtle/subturtle/ctl <command> [name] [options]"
  echo ""
  echo "Commands:"
  echo "  start  [name] [--type TYPE] [--timeout DURATION] [--skill NAME ...]"
  echo "         Spawn a SubTurtle (default timeout: ${DEFAULT_TIMEOUT})"
  echo "         Types: slow, yolo, yolo-codex (default), yolo-codex-spark"
  echo "           slow       — Plan -> Groom -> Execute -> Review (4 calls/iter)"
  echo "           yolo       — Single Claude call per iteration (Ralph loop)"
  echo "           yolo-codex — Single Codex call per iteration (Ralph loop)"
  echo "           yolo-codex-spark — Single Codex Spark call per iteration (Ralph loop)"
  echo "         Skills: repeatable --skill flags load Claude Code skills (e.g. --skill frontend --skill testing)"
  echo "  spawn [name] [--type TYPE] [--timeout DURATION] [--state-file PATH|-] [--cron-interval DURATION] [--skill NAME ...]"
  echo "         Create workspace, seed CLAUDE.md from --state-file/stdin, start SubTurtle, and auto-register cron"
  echo "         Defaults: --type yolo-codex, --timeout ${DEFAULT_TIMEOUT}, --cron-interval 10m"
  echo "  stop   [name]                        Stop a SubTurtle gracefully"
  echo "  stopall                              Stop all active SubTurtles gracefully"
  echo "  status [name]                        Check if running + time remaining"
  echo "  logs   [name]                        Tail a SubTurtle's log"
  echo "  list   [--archived]                 List active SubTurtles (default) or archived SubTurtles"
  echo "  archive <name>                      Archive a stopped SubTurtle to .superturtle/subturtles/.archive/<name>/"
  echo "  gc [--max-age DURATION]             Archive stopped SubTurtles older than max age (default: 1d)"
  echo "  reschedule-cron <name> <interval>   Update recurring cron interval (e.g. 1m, 5m)"
  echo ""
  echo "Timeout durations: 30m, 1h, 2h, 4h, etc. Default: ${DEFAULT_TIMEOUT}"
  echo "SubTurtles auto-terminate when their timeout expires."
  echo ""
  echo "IMPORTANT: CLAUDE.md must exist in the workspace before starting."
  echo "The meta agent writes it — ctl does NOT auto-seed from root."
  echo ""
  echo "Each SubTurtle gets its own workspace at .superturtle/subturtles/<name>/ with"
  echo "its own CLAUDE.md, AGENTS.md symlink, PID file, and log file."
  exit 1
}

# --- Main ---
if [[ $# -lt 1 ]]; then
  usage
fi

CMD="$1"
shift

ensure_run_state_files

case "$CMD" in
  start)
    # Optional first positional arg is name. If first arg is a flag, use default.
    NAME="default"
    if [[ $# -gt 0 && "$1" != --* ]]; then
      NAME="$1"
      shift
    fi
    do_start "$NAME" "$@"
    ;;
  spawn)
    # Optional first positional arg is name. If first arg is a flag, use default.
    NAME="default"
    if [[ $# -gt 0 && "$1" != --* ]]; then
      NAME="$1"
      shift
    fi
    do_spawn "$NAME" "$@"
    ;;
  stop)   do_stop "${1:-default}" ;;
  stopall) do_stopall ;;
  status) do_status "${1:-default}" ;;
  logs)   do_logs "${1:-default}" ;;
  list)   do_list "$@" ;;
  archive)
    if [[ $# -ne 1 ]]; then
      echo "Usage: ./super_turtle/subturtle/ctl archive <name>" >&2
      exit 1
    fi
    do_archive "$1"
    ;;
  gc)     do_gc "$@" ;;
  reschedule-cron)
    if [[ $# -ne 2 ]]; then
      echo "Usage: ./super_turtle/subturtle/ctl reschedule-cron <name> <interval>" >&2
      exit 1
    fi
    do_reschedule_cron "$1" "$2"
    ;;
  *)      usage ;;
esac
